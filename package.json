{
  "name": "budget-dispatcher",
  "version": "1.0.0",
  "type": "module",
  "description": "Budget-aware opportunistic dispatcher with direct model API support",
  "scripts": {
    "dispatch": "node scripts/dispatch.mjs",
    "estimate": "node scripts/estimate-usage.mjs",
    "check-idle": "node scripts/check-idle.mjs",
    "dashboard": "node scripts/dashboard.mjs",
    "control": "node scripts/control.mjs",
    "test": "node --test \"scripts/lib/__tests__/*.test.mjs\"",
    "status": "node scripts/status.mjs",
    "monitor": "node scripts/remote-status.mjs",
    "monitor:watch": "node scripts/remote-status.mjs --watch 120",
    "track-merges": "node scripts/track-merges.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@mistralai/mistralai": "^1.0.0",
    "@octokit/plugin-throttling": "^9.4.0",
    "@octokit/rest": "^21.1.0",
    "ajv": "^8.18.0",
    "onnxruntime-node": "^1.20.1"
  }
}
