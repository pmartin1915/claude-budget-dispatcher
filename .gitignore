node_modules/
*.log
.DS_Store

# Machine-specific config (gitignored, layered over config/shared.json at runtime)
config/budget.json
config/local.json
config/PAUSED

# Runtime state — regenerated on every run
status/usage-estimate.json
status/budget-dispatch-log.jsonl
status/budget-dispatch-last-run.json
status/health.json
status/fleet-*.json
status/alerting-state.json
status/merge-tracker.json
status/last-auto-pull.json

# Rotated JSONL archives + ad-hoc backups produced during operator cleanup
status/budget-dispatch-log-archive-*.jsonl
status/*.bak-*

# Weekly maintenance marker files (C-4 git fsck, S-8 npm audit)
status/last-*.txt

# Keep status/ as a directory in git
!status/.gitkeep

# Editor junk
.vscode/
.idea/
*.swp

# Headless runner log directory (keep dir, ignore contents)
status/dispatcher-runs/*
!status/dispatcher-runs/.gitkeep

# Compiled tray app (rebuild with scripts\build-tray.cmd)
bin/

# Backups produced by scripts/migrate-local-projects.mjs (timestamped)
config/local.json.bak-*
